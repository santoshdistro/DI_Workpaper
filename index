function setErr(msg) { const b = $("bErr"); b.textContent = msg || ""; b.style.display = msg ? "block" : "none"; }
function setBusy(msg) {
  const b = $("bBusy"); b.textContent = msg ? "⏳ " + msg : ""; b.style.display = msg ? "block" : "none";
  ["btnAnalyze", "btnGenerate", "btnSign", "btnDlWp", "btnDlEv", "btnDlRec"].forEach((id) => { const el = $(id); if (el && msg) el.dataset.wasDisabled = el.disabled ? "1" : ""; if (el) el.disabled = !!msg || el.dataset.wasDisabled === "1"; });
  if (!msg) refreshIntakeButton();
}

