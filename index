$("fEvid").addEventListener("change", async (e) => {
  const files = Array.from(e.target.files || []); if (!files.length) return;
  setErr("");
  try {
    for (const file of files) {
      const id = "EV" + (S.evidence.length + 1);
      setBusy(`Reading evidence ${id}: ${file.name}…`);
      const isImage = (file.type || "").startsWith("image/") || /\.(png|jpe?g|webp|gif)$/i.test(file.name);
      if (isImage) {
        const supported = ["image/png", "image/jpeg", "image/webp", "image/gif"];
        let mt = supported.includes(file.type) ? file.type : null;
        if (!mt) {
          if (/\.png$/i.test(file.name)) mt = "image/png";
          else if (/\.jpe?g$/i.test(file.name)) mt = "image/jpeg";
          else if (/\.webp$/i.test(file.name)) mt = "image/webp";
          else if (/\.gif$/i.test(file.name)) mt = "image/gif";
        }
        if (!mt) throw new Error(`"${file.name}" is an unsupported image format (e.g. HEIC). Convert to PNG or JPG and re-upload.`);
        const b64 = await readB64(file);
        const out = await callClaude([{ role: "user", content: [
          { type: "image", source: { type: "base64", media_type: mt, data: b64 } },
          { type: "text", text: "This is an audit evidence screenshot. Extract every visible field and value as plain text lines (Field: Value). Then add one line starting 'Summary:' describing what this document is. Output text only." },
        ] }]);
        S.evidence.push({ id, name: file.name, kind: "image", text: out });
      } else {
        S.evidence.push({ id, name: file.name, kind: "doc", text: await extractDoc(file) });
      }
    }
    $("hEvid").textContent = `${S.evidence.length} item(s): ${S.evidence.map((x) => x.id).join(", ")}`;
    $("uEvid").classList.add("has"); $("tEvid").classList.add("on"); $("tEvid").textContent = "✓";
    $("evList").innerHTML = S.evidence.map((x) =>
      `<div><span class="id">${x.id}</span><span>${esc(x.name)}</span><span>· ${x.kind === "image" ? "screenshot (AI-read)" : "document"}</span></div>`).join("");
  } catch (err) { setErr("Evidence reading failed: " + err.message); }
  finally { setBusy(""); e.target.value = ""; }
});

