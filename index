    const a = S.annots.find((x) => x.id === e.id) || {};
    const aoa = [[`${e.id} — ${e.name}`], [], ["ANNOTATION:"],
      [(S.annotEdits[e.id] !== undefined ? S.annotEdits[e.id] : a.annotation) || ""], [],
      ["EXTRACTED CONTENT:"], ...e.text.split("\n").map((line) => [line])];
    XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(aoa), safeSheetName(`${e.id} ${e.name}`));
  });
  XLSX.writeFile(wb, "Evidence_Workbook_Annotated.xlsx");
});

