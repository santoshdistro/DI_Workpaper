    const val = S.annotEdits[a.id] !== undefined ? S.annotEdits[a.id] : a.annotation;
    return `<tr><td style="font-family:monospace">${esc(a.id)}</td><td>${esc(a.name)}</td><td>${dec ? esc(val) : "<i>Rejected</i>"}</td><td style="text-align:center;color:${dec ? "#1E6E5C" : "#A33B3B"};font-weight:bold">${dec ? "✓" : "✗"}</td></tr>`;
  }).join("");
  const html = `<html><head><meta charset="utf-8"></head><body style="font-family:Calibri,Arial,sans-serif;color:#2C3543">
<h1 style="font-size:18pt">D&amp;I Testing — Preparation &amp; Evidence Record</h1>
<p><b>Workpaper template:</b> ${esc(S.templateName)}<br><b>Walkthrough source:</b> ${esc(S.walkName)}<br><b>Policy:</b> ${esc(S.policyName)}<br>
<b>Evidence items:</b> ${S.evidence.length || "None — implementation assessed by inquiry only (limitation flagged)"}<br>
<b>Maker sign-off:</b> ${S.signedAt ? S.signedAt.toLocaleString() : ""}<br>
<b>Method:</b> AI-assisted draft; every entry dispositioned by the maker (✓ accepted / ✗ rejected) before inclusion.</p>
<h2 style="font-size:13pt">Workpaper entries</h2>
<table border="1" cellspacing="0" cellpadding="6" style="border-collapse:collapse;font-size:10pt;width:100%">
<tr style="background:#16243A;color:#fff"><th>Cell</th><th>Field</th><th>Value entered</th><th>Source</th><th>Maker</th></tr>${fillRows}</table>
${S.annots.length ? `<h2 style="font-size:13pt">Evidence annotations</h2><table border="1" cellspacing="0" cellpadding="6" style="border-collapse:collapse;font-size:10pt;width:100%"><tr style="background:#16243A;color:#fff"><th>ID</th><th>File</th><th>Annotation</th><th>Maker</th></tr>${annotRows}</table>` : ""}
<p style="font-size:9pt;color:#6B7585;margin-top:14pt">Generated by the D&amp;I Workpaper Assistant (pilot demonstration). Pending reviewer sign-off.</p>
</body></html>`;
  downloadBlob(html, "Preparation_Record.doc", "application/msword");
});

