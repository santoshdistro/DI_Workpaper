$("btnAnalyze").addEventListener("click", async () => {
  setBusy("Reading template structure and inferring the schema…"); setErr("");
  try {
    const cells = sheetToCellList(S.workbook.Sheets[S.sheetName]);
    const prompt = `You are analyzing an IT audit workpaper Excel template. Some cells contain LABELS or long GUIDANCE text; the preparer fills the EMPTY cell beside (one column right) or below each label.

Non-empty cells (address: content):
${cells.map((c) => `${c.addr}: ${c.value}`).join("\n")}

Identify up to 14 cells the preparer must FILL. Treat long guidance paragraphs as guidance, not labels. Respond ONLY with a JSON array:
[{"cell":"B3","label":"Control Risk","expects":"Low/Medium/High with rationale"}]
"cell" = address of the EMPTY cell to fill. Keep "expects" under 8 words.`;
