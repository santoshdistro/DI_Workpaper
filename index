$("btnDlWp").addEventListener("click", async () => {
  setBusy("Writing values into your original template (format-preserving)…");
  const ok = $("bExport");
  try {
    const accepted = {};
    S.fills.forEach((f) => { if (S.decisions[f.cell]) accepted[f.cell] = S.edits[f.cell] !== undefined ? S.edits[f.cell] : f.value; });
    const blob = await writeIntoOriginal(S.templateBuf, S.sheetName, accepted);
    downloadBlob(blob, "DI_Workpaper_Filled.xlsx");
    ok.textContent = "✓ Exported with original formatting fully preserved — only the accepted cells were written.";
    ok.style.display = "block";
  } catch (e) {
    try {
      const ws = S.workbook.Sheets[S.sheetName];
      S.fills.forEach((f) => { if (S.decisions[f.cell]) ws[f.cell] = { t: "s", v: S.edits[f.cell] !== undefined ? S.edits[f.cell] : f.value }; });
      const range = XLSX.utils.decode_range(ws["!ref"] || "A1");
      S.fills.forEach((f) => { const dc = XLSX.utils.decode_cell(f.cell); if (dc.r > range.e.r) range.e.r = dc.r; if (dc.c > range.e.c) range.e.c = dc.c; });
      ws["!ref"] = XLSX.utils.encode_range(range);
      XLSX.writeFile(S.workbook, "DI_Workpaper_Filled.xlsx");
      ok.textContent = `Exported via fallback writer — formatting may be simplified (${e.message}).`;
      ok.style.display = "block";
    } catch (e2) { setErr("Export failed: " + e2.message); }
  } finally { setBusy(""); }
});

