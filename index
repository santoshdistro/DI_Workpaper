// ---------- generation ----------
function baseContext() {
  const presetText = $("preset").value;
  const extraContext = $("extraCtx").value.trim();
  const evidenceBlock = S.evidence.length
    ? S.evidence.map((e) => `[${e.id} — ${e.name}]\n${e.text.slice(0, 1500)}`).join("\n\n")
    : "NONE PROVIDED";
  return `You are an IT audit senior preparing a Design & Implementation (D&I) workpaper.

WALKTHROUGH / INQUIRY NOTES:
${S.walkText.slice(0, 5000)}

POLICY:
${S.policyText.slice(0, 3000)}

EVIDENCE ITEMS:
${evidenceBlock}

${presetText ? "FOCUS: " + presetText : ""}${extraContext ? "\nPREPARER CONTEXT: " + extraContext : ""}

STRICT RULES:
- Design evaluation: base on inquiry/walkthrough; name the role inquired with and list numbered process steps.
- Implementation evaluation: ONLY reference evidence items that exist above, citing them as [EV1 — filename]. Include specific details (names, dates, roles) from the evidence.
- If EVIDENCE ITEMS is "NONE PROVIDED": the implementation field MUST state that implementation was assessed through inquiry and walkthrough observation only, that corroborating evidence is yet to be obtained, and flag this as a limitation. NEVER invent evidence, document names, or references.
- Short fields (risk, level, competency, aggregation): 1-2 sentences. Narrative fields: 3-6 sentences.
- Note gaps or exceptions honestly; if none, state "No exception noted."`;
}

$("btnGenerate").addEventListener("click", async () => {
  setErr("");
  try {
    const ctx = baseContext();
    const batches = chunk(S.schema, 3);
    const allFills = [];
    for (let i = 0; i < batches.length; i++) {
      setBusy(`Drafting fields ${i * 3 + 1}–${Math.min((i + 1) * 3, S.schema.length)} of ${S.schema.length}…`);
      const b = batches[i];
      const prompt = `${ctx}

FILL ONLY THESE FIELDS:
${b.map((s) => `${s.cell} | ${s.label} | ${s.expects}`).join("\n")}

Respond ONLY with a JSON array:
[{"cell":"B3","value":"...","source":"Inquiry with control owner 21-04-2026"}]
Keep each "source" under 12 words (cite Inquiry, Policy, or [EVn]).`;
      const out = await callClaude([{ role: "user", content: prompt }]);
      allFills.push(...parseClaudeJSON(out));
    }
    S.fills = allFills;

    S.annots = [];
    if (S.evidence.length) {
      setBusy("Annotating evidence items…");
      const out = await callClaude([{ role: "user", content: `${ctx}

For EACH evidence item, write an audit annotation (2-3 sentences): what the document is, which control attribute(s) it evidences, and the key fields relied upon (names, dates). Respond ONLY with a JSON array:
[{"id":"EV1","annotation":"..."}]` }]);
      const parsed = parseClaudeJSON(out);
      S.annots = S.evidence.map((e) => ({
        id: e.id, name: e.name,
        annotation: (parsed.find((p) => p.id === e.id) || {}).annotation || "Annotation not generated — add manually.",
      }));
    }

    S.decisions = {}; S.edits = {}; S.annotEdits = {};
    S.fills.forEach((f) => (S.decisions[f.cell] = null));
    S.annots.forEach((a) => (S.decisions["@" + a.id] = null));
    renderReview();
    goStep(2);
  } catch (e) { setErr("Draft generation failed: " + e.message + " — press the button to retry."); }
  finally { setBusy(""); }
});

// ---------- review ----------
const allDecided = () => Object.keys(S.decisions).length > 0 && Object.values(S.decisions).every((v) => v !== null);
const acceptedCount = () => Object.values(S.decisions).filter((v) => v === true).length;

function renderReview() {
  const host = $("fillCards");
  host.innerHTML = "";
  const mkCard = (key, refLabel, refCls, title, value, source, onEdit) => {
    const dec = S.decisions[key];
    const card = document.createElement("div");
    card.className = "card" + (dec === true ? " acc" : dec === false ? " rej" : "");
    const head = document.createElement("div");
    head.className = "head";
    head.innerHTML = `<span class="cellref ${refCls}">${esc(refLabel)}</span><span class="l">${esc(title)}</span>`;
    const btns = document.createElement("div");
    btns.style.display = "flex"; btns.style.gap = "8px";
    const mk = (sym, cls, val) => {
      const b = document.createElement("button");
      b.className = `dbtn ${cls}` + (dec === val ? " sel" : "");
      b.textContent = sym;
      b.onclick = () => { S.decisions[key] = val; renderReview(); };
      return b;
    };
    btns.append(mk("✓", "acc", true), mk("✗", "rej", false));
    head.appendChild(btns);
    card.appendChild(head);
    const ta = document.createElement("textarea");
    ta.value = value;
    ta.rows = Math.min(6, Math.max(1, Math.ceil(value.length / 90)));
    ta.oninput = () => onEdit(ta.value);
    card.appendChild(ta);
    if (source) {
      const src = document.createElement("div");
      src.className = "src"; src.textContent = "Source — " + source;
      card.appendChild(src);
    }
    return card;
  };

  S.fills.forEach((f) => {
    const sch = S.schema.find((s) => s.cell === f.cell) || {};
    host.appendChild(mkCard(f.cell, f.cell, "", sch.label || f.cell,
      S.edits[f.cell] !== undefined ? S.edits[f.cell] : f.value, f.source || "",
      (v) => { S.edits[f.cell] = v; }));
  });
  if (S.annots.length) {
    const h = document.createElement("div");
    h.className = "section-head"; h.textContent = "Evidence annotations";
    host.appendChild(h);
    S.annots.forEach((a) => {
      host.appendChild(mkCard("@" + a.id, a.id, "ev", a.name,
        S.annotEdits[a.id] !== undefined ? S.annotEdits[a.id] : a.annotation, "",
        (v) => { S.annotEdits[a.id] = v; }));
    });
  }
  $("counter").textContent = `${acceptedCount()} / ${Object.keys(S.decisions).length} accepted`;
  $("btnSign").disabled = !allDecided();
  $("signWarn").style.display = allDecided() ? "none" : "block";
}

